# Application
APP_NAME=Revio AI
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-64-char-random-string
ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@db.xxxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://api.revio.ai/api/v1/crm/hubspot/oauth/callback
HUBSPOT_WEBHOOK_SECRET=

# Salesforce OAuth
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://api.revio.ai/api/v1/crm/salesforce/oauth/callback

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o

# Email & SMS
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=revive@revio.ai
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@revio.ai
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# External signal APIs
APOLLO_API_KEY=
CRUNCHBASE_API_KEY=

# Slack alerts
SLACK_WEBHOOK_URL=

# Sentry
SENTRY_DSN=

# Agent settings
REVIVE_INACTIVITY_DAYS=30
PULSE_REVENUE_RISK_THRESHOLD=50000
AUTO_SEND_ENABLED=true
